    {
      "id": "fact_acp_best_practice_002",
      "content": "ACP 协作工作流：1) 任务定义写入 ../user-data/workspace/acp_task_xxx.json；2) 输入数据放 ../user-data/uploads/；3) Prompt 引用任务文件路径；4) 输出结果写入 ../user-data/outputs/",
      "category": "knowledge",
      "confidence": 0.95,
      "createdAt": "2026-04-02T15:25:00.000000Z",
